{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/human-data-lib/catalog.schema.json",
  "title": "human-data-lib catalog",
  "type": "object",
  "required": ["schema_version", "generated_at", "scope_note", "entries"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "string", "minLength": 1 },
    "generated_at": { "type": "string", "minLength": 1 },
    "scope_note": { "type": "string", "minLength": 1 },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/entry" }
    }
  },
  "$defs": {
    "entry": {
      "type": "object",
      "required": [
        "id",
        "name",
        "artifact_type",
        "domains",
        "modalities",
        "tasks",
        "ecosystems",
        "scales",
        "official_url",
        "repo_url",
        "summary_ja"
      ],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
        "name": { "type": "string", "minLength": 1 },
        "artifact_type": { "type": "string", "minLength": 1 },
        "domains": { "$ref": "#/$defs/stringList" },
        "modalities": { "$ref": "#/$defs/stringList" },
        "tasks": { "$ref": "#/$defs/stringList" },
        "ecosystems": { "$ref": "#/$defs/stringList" },
        "scales": { "$ref": "#/$defs/stringList" },
        "official_url": { "type": "string", "format": "uri" },
        "repo_url": { "type": "string", "format": "uri" },
        "license": { "type": "string", "minLength": 1 },
        "maturity": { "type": "string", "minLength": 1 },
        "summary_ja": { "type": "string", "minLength": 1 },
        "notes": { "type": "string", "minLength": 1 }
      }
    },
    "stringList": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
